<apex:page controller="AccountPdfCustomController" 
           renderAs="pdf" 
           showHeader="false" 
           sidebar="false" 
           cache="false"
           standardStylesheets="false" 
           applyBodyTag="false" 
           applyHtmlTag="false">
    <html>
        <head>
            <style>
                .pdf-page {
                    page-break-after: always;
                    box-sizing: border-box;
                }
                .pdf-page:last-child {
                    page-break-after: avoid;
                }
                .section {
                    margin-bottom: 30px;
                    padding: 10px;
                }
                .qr-code-box {
                    text-align: center;
                    margin: 0 auto;
                }
                .qr-code-box img {
                    width: 100px;
                    height: 100px;
                }
                table {
                    width: 100%;
                    border-collapse: collapse;
                }
                th, td {
                    padding: 8px;
                    text-align: left;
                }
            </style>
        </head>
        <body>

            <apex:repeat value="{!pdfPages}" var="page">
                <div class="pdf-page">
                    
                    <div class="header">
                        <h1 class="title" style="text-align: center;">Account Overview - {!page.city}</h1>
                        <p style="text-align: center;">Generated on: {!NOW()}</p>
                    </div>

                    <div class="section">
                        <apex:panelGroup rendered="{!NOT(ISBLANK(page.qrCodeVersionId))}">
                            <div class="qr-code-box">
                                <h4>Scan Unique QR Code: {!page.city}</h4>
                                <img src="/sfc/servlet.shepherd/version/download/{!page.qrCodeVersionId}" alt="Account QR Code" />
                            </div>
                        </apex:panelGroup>
                    </div>

                    <div class="section">
                        <h3>General Details</h3>
                        <table>
                            <tr>
                                <th>Account Name</th>
                                <td>{!page.acc.Name}</td>
                            </tr>
                            <tr>
                                <th>Account Number</th>
                                <td>{!page.acc.AccountNumber}</td>
                            </tr>
                            <tr>
                                <th>Phone</th>
                                <td>{!page.acc.Phone}</td>
                            </tr>
                            <tr>
                                <th>Industry</th>
                                <td>{!page.acc.Industry}</td>
                            </tr>
                        </table>
                    </div>

                    <div class="section">
                        <apex:outputPanel rendered="{!page.acc.Industry == 'Technology'}">
                            <h3>Special Tech Account Notes</h3>
                            <p>This section only appears for Technology industry accounts.</p>
                        </apex:outputPanel>
                        
                        <apex:outputPanel rendered="{!page.acc.Industry != 'Technology'}">
                            <h3>Standard Account Notes</h3>
                            <p>This section appears for all other industries.</p>
                        </apex:outputPanel>
                    </div>

                </div>
            </apex:repeat>

        </body>
    </html>
</apex:page>